alert arp any any -> any any (msg:"NETLAB ARP spoof possible"; arp_opcode:2; threshold:type threshold, track by_src, count 8, seconds 5; sid:2000001; rev:1;)
alert tcp any any -> 10.0.0.10 any (msg:"NETLAB SYN flood"; flags:S; threshold:type threshold, track by_src, count 80, seconds 2; sid:2000002; rev:1;)
alert udp any 53 -> any any (msg:"NETLAB high DNS response rate"; threshold:type threshold, track by_src, count 60, seconds 5; sid:2000003; rev:1;)
